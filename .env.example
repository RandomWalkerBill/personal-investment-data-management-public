# Optional: make Futu annual bill accounts align with the default monthly
# account id `futu_hk_main`. Do not commit your real account number.
FUTU_PRIMARY_ACCOUNT_NUMBER=<your-futu-securities-account-number>

# Optional: override Node.js path if you want to generate the Excel review
# workbook. Most CLI flows can use --skip-workbook and do not need Node.js.
NODE_BIN=<path-to-node>

# Local private database path used in examples. Do not commit the DB.
INVESTMENT_DB_PATH=work/investment.sqlite
